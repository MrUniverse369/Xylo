<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta http-equiv="X-UA-Compatible" content="IE=edge" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title></title>
  </head>
  <body>
    <%- include('header.ejs') %>

    <!-- Smart tools section -->
    <section>
      <div class="SmartTools">
        <p class="TitleCenter">
          Smart tools <strong>your business</strong><br /><b>needs</b>
        </p>
        <p class="SmartToolscontent">
          From taking payments and selling online to processing orders and
          managing your money — with Xylo, it's all possible. 4 million
          businesses have already chosen us to be their partner, let's see how
          we can help you too.
        </p>
        <ul>
          <li><a href="/ContactSales">Contact Sales</a></li>
          <li><a href="/Shop">Shop hardware</a></li>
        </ul>
      </div>
      <div class="SmartToolsImg">
        <img src="/img/SmartTools_1.jpg" alt="employees in a small business" />
        <img src="/img/SmartTools_2.jpg" alt="employees in a small business" />
        <img src="/img/SmartTools_3.jpg" alt="employees in a small business" />
      </div>
    </section>

    <!-- Our Full Range of Products -->
    <section>
      <p class="TitleCenter">Find out more about <strong>our full range of products</strong></p>

      <div class="Products_1">

        <div onclick="window.location.href='/products';">
          <div class="Products_1__icon">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round">
              <rect x="3" y="6" width="18" height="13" rx="2"/>
              <path d="M3 10h18"/>
              <path d="M7 15h4M15 15h2"/>
            </svg>
          </div>
          <h2>Card Readers</h2>
        </div>

        <div onclick="window.location.href='/products';">
          <div class="Products_1__icon">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round">
              <rect x="2" y="3" width="20" height="13" rx="2"/>
              <path d="M8 21h8M12 17v4"/>
              <path d="M7 8h2M11 8h6M7 11h4M13 11h4"/>
            </svg>
          </div>
          <h2>POS Solutions</h2>
        </div>

        <div onclick="window.location.href='/products';">
          <div class="Products_1__icon">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round">
              <rect x="7" y="2" width="10" height="16" rx="2"/>
              <path d="M10 22h4M12 18v4"/>
              <path d="M10 6h4M10 9h4M10 12h2"/>
            </svg>
          </div>
          <h2>Self Service Kiosk</h2>
        </div>

        <div onclick="window.location.href='/products';">
          <div class="Products_1__icon">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round">
              <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/>
              <polyline points="14 2 14 8 20 8"/>
              <line x1="8" y1="13" x2="16" y2="13"/>
              <line x1="8" y1="17" x2="12" y2="17"/>
            </svg>
          </div>
          <h2>Invoice</h2>
        </div>

      </div>
    </section>

    <!-- Featured Product -->
    <section>
      <div class="FeaturedProduct">
        <div class="FeaturedProductItemOne">
          <img src="/img/SmartTools_2.jpg" />
        </div>
        <div class="FeaturedProductItemTwo">
          <h2>Payments. Software. Hardware.<br>All by Xylo</h2>
          <p>Xylo Register is a fully integrated point-of-sale system
            that lets you manage card and contactless payments, online sales, click and collect and delivery,
            all from one POS. This touchscreen till system is built to be faster, more powerful and more reliable,
            right out of the box – no extra tablets, apps or card terminal required.</p>
          <ul>
            <li><a class="btn" href="/ContactSales">Learn More</a></li>
            <li><a class="btn" href="/shop">Shop Hardware</a></li>
          </ul>
        </div>
      </div>
    </section>

    <%- include('footer.ejs') %>
  </body>
</html>
