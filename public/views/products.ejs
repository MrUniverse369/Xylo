<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta http-equiv="X-UA-Compatible" content="IE=edge" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Products</title>
  </head>
  <body>
    <%- include('header.ejs') %>

    <div class="ProductsContainer">

      <!-- Hero -->
      <div class="ProductsHero">
        <h1>Built for every kind of business</h1>
        <p>From compact card readers to full self-service kiosks — XYLO has the hardware and software your operation needs.</p>
      </div>

      <!-- Icon cards -->
      <div class="ProductsGrid">

        <!-- POS Systems -->
        <div class="ProductCard">
          <div class="ProductCard__icon">
            <!-- Monitor / till SVG -->
            <svg viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
              <rect x="2" y="3" width="20" height="13" rx="2"/>
              <path d="M8 21h8M12 17v4"/>
              <path d="M7 8h2M11 8h6M7 11h4M13 11h4"/>
            </svg>
          </div>
          <p class="ProductCard__number">01 — Point of Sale</p>
          <h2 class="ProductCard__title">Point of Sale Systems</h2>
          <p class="ProductCard__desc">
            Browse our selection of premium POS systems from leading brands. Whether you need compact designs, advanced software features, or all-in-one solutions — we have the right fit for retail, restaurants, and service-based operations.
          </p>
          <ul class="ProductCard__features">
            <li>Seamless payment processing</li>
            <li>Real-time inventory management</li>
            <li>Advanced sales reporting</li>
            <li>Multi-location support</li>
          </ul>
          <div class="ProductCard__actions">
            <a class="btn" href="/ContactSales">Learn More</a>
            <a class="btn" href="/shop">Shop Hardware</a>
          </div>
        </div>

        <!-- Self-Service Kiosks -->
        <div class="ProductCard">
          <div class="ProductCard__icon">
            <!-- Kiosk / standing terminal SVG -->
            <svg viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
              <rect x="7" y="2" width="10" height="16" rx="2"/>
              <path d="M10 22h4M12 18v4"/>
              <path d="M10 6h4M10 9h4M10 12h2"/>
            </svg>
          </div>
          <p class="ProductCard__number">02 — Self Service</p>
          <h2 class="ProductCard__title">Self-Service Kiosks</h2>
          <p class="ProductCard__desc">
            Enhance your business with our range of self-service kiosks from top manufacturers. Perfect for retail, restaurants, and customer-facing operations — featuring modern touchscreens and customisable interfaces.
          </p>
          <ul class="ProductCard__features">
            <li>Reduce customer wait times</li>
            <li>Touchscreen order placement</li>
            <li>Customisable branding &amp; UI</li>
            <li>Contactless &amp; chip payment ready</li>
          </ul>
          <div class="ProductCard__actions">
            <a class="btn" href="/ContactSales">Learn More</a>
            <a class="btn" href="/shop">Shop Hardware</a>
          </div>
        </div>

        <!-- Card Readers -->
        <div class="ProductCard">
          <div class="ProductCard__icon">
            <!-- Card reader SVG -->
            <svg viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
              <rect x="3" y="6" width="18" height="13" rx="2"/>
              <path d="M3 10h18"/>
              <path d="M7 15h4M15 15h2"/>
            </svg>
          </div>
          <p class="ProductCard__number">03 — Card Readers</p>
          <h2 class="ProductCard__title">Card Readers</h2>
          <p class="ProductCard__desc">
            Explore our high-performance card readers from trusted brands, designed to streamline payment processing. From compact mobile options to fully-featured countertop models — compatible with contactless, chip, and swipe.
          </p>
          <ul class="ProductCard__features">
            <li>Contactless, chip &amp; swipe</li>
            <li>Compact &amp; portable options</li>
            <li>Fast transaction speeds</li>
            <li>Works with all major networks</li>
          </ul>
          <div class="ProductCard__actions">
            <a class="btn" href="/ContactSales">Learn More</a>
            <a class="btn" href="/shop">Shop Hardware</a>
          </div>
        </div>

      </div>
      <!-- end ProductsGrid -->

    </div>

    <%- include('footer.ejs') %>
  </body>
</html>
