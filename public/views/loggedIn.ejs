<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>My Account – Fintact</title>
    <link rel="stylesheet" href="/css/style.css" />
    <style>
      .dashboard {
        max-width: 1000px;
        margin: 2rem auto;
        padding: 0 1.5rem;
      }

      .dashboard-greeting {
        margin-bottom: 2rem;
      }
      .dashboard-greeting h1 {
        font-size: 1.8rem;
        margin: 0 0 0.25rem;
      }
      .dashboard-greeting p {
        color: #666;
        margin: 0;
        font-size: 0.95rem;
      }

      .dashboard-grid {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 1.5rem;
      }
      @media (max-width: 680px) {
        .dashboard-grid {
          grid-template-columns: 1fr;
        }
      }

      .card {
        background: #fff;
        border: 1px solid #e5e5e5;
        border-radius: 12px;
        padding: 1.5rem;
      }
      .card h2 {
        font-size: 1rem;
        font-weight: 600;
        text-transform: uppercase;
        letter-spacing: 0.05em;
        color: #888;
        margin: 0 0 1rem;
      }
      .card.full-width {
        grid-column: 1 / -1;
      }

      /* Profile row */
      .profile-row {
        display: flex;
        align-items: center;
        gap: 1rem;
      }
      .avatar {
        width: 56px;
        height: 56px;
        border-radius: 50%;
        background: #f0f0f0;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 1.4rem;
        font-weight: 700;
        color: #555;
        flex-shrink: 0;
      }
      .profile-info p {
        margin: 0.2rem 0;
        font-size: 0.92rem;
        color: #555;
      }
      .profile-info strong {
        color: #222;
      }

      /* Status badge */
      .badge {
        display: inline-block;
        padding: 0.2rem 0.65rem;
        border-radius: 99px;
        font-size: 0.78rem;
        font-weight: 600;
      }
      .badge-active {
        background: #e6f4ea;
        color: #1e7e34;
      }
      .badge-inactive {
        background: #fdecea;
        color: #b71c1c;
      }
      .badge-pending {
        background: #fff8e1;
        color: #f57f17;
      }
      .badge-open {
        background: #e3f2fd;
        color: #1565c0;
      }
      .badge-high {
        background: #fce4ec;
        color: #880e4f;
      }

      /* Plan card */
      .plan-name {
        font-size: 1.5rem;
        font-weight: 700;
        margin: 0 0 0.5rem;
      }
      .plan-meta {
        font-size: 0.9rem;
        color: #555;
        margin: 0.25rem 0;
      }
      .plan-price {
        font-size: 1.1rem;
        font-weight: 600;
        margin: 0.75rem 0;
      }
      .plan-limits {
        display: flex;
        gap: 1.5rem;
        margin-top: 0.75rem;
      }
      .plan-limits span {
        font-size: 0.85rem;
        color: #555;
      }
      .plan-limits strong {
        display: block;
        font-size: 1.1rem;
        color: #222;
      }

      /* Orders table */
      .data-table {
        width: 100%;
        border-collapse: collapse;
        font-size: 0.9rem;
      }
      .data-table th {
        text-align: left;
        padding: 0.5rem 0.75rem;
        border-bottom: 2px solid #f0f0f0;
        color: #888;
        font-weight: 600;
        font-size: 0.78rem;
        text-transform: uppercase;
      }
      .data-table td {
        padding: 0.6rem 0.75rem;
        border-bottom: 1px solid #f5f5f5;
      }
      .data-table tr:last-child td {
        border-bottom: none;
      }
      .data-table .muted {
        color: #aaa;
        font-size: 0.82rem;
      }

      /* Address card */
      .address-block p {
        margin: 0.2rem 0;
        font-size: 0.92rem;
        color: #555;
      }

      /* Tickets */
      .ticket-row {
        display: flex;
        justify-content: space-between;
        align-items: center;
        padding: 0.65rem 0;
        border-bottom: 1px solid #f5f5f5;
      }
      .ticket-row:last-child {
        border-bottom: none;
      }
      .ticket-subject {
        font-size: 0.92rem;
        font-weight: 500;
      }
      .ticket-date {
        font-size: 0.8rem;
        color: #aaa;
        margin-top: 0.15rem;
      }
      .ticket-badges {
        display: flex;
        gap: 0.4rem;
        align-items: center;
      }

      /* Buttons */
      .btn-primary {
        display: inline-block;
        margin-top: 1rem;
        padding: 0.55rem 1.2rem;
        background: #111;
        color: #fff;
        border-radius: 8px;
        text-decoration: none;
        font-size: 0.9rem;
      }
      .btn-outline {
        display: inline-block;
        margin-top: 1rem;
        padding: 0.5rem 1.1rem;
        border: 1px solid #ccc;
        color: #333;
        border-radius: 8px;
        text-decoration: none;
        font-size: 0.9rem;
      }
      .no-data {
        color: #aaa;
        font-size: 0.9rem;
        font-style: italic;
      }
    </style>
  </head>
  <body>
    <%- include('header.ejs') %>

    <div class="dashboard">
      <!-- Greeting -->
      <div class="dashboard-greeting">
        <h1>Welcome back, <%= user.first_name || user.email %>!</h1>
        <p>Here's everything on your Fintact account.</p>
      </div>

      <div class="dashboard-grid">
        <!-- Profile card -->
        <div class="card">
          <h2>Profile</h2>
          <div class="profile-row">
            <div class="avatar">
              <%= (user.first_name || user.email).charAt(0).toUpperCase() %>
            </div>
            <div class="profile-info">
              <strong>
                <%= user.first_name && user.last_name ? user.first_name + ' ' +
                user.last_name : user.email %>
              </strong>
              <p><%= user.email %></p>
              <% if (user.company_name) { %>
              <p><%= user.company_name %></p>
              <% } %> <% if (user.phone) { %>
              <p><%= user.phone %></p>
              <% } %>
              <p>
                Member since <%= new
                Date(user.created_at).toLocaleDateString('en-GB',{year:'numeric',month:'long'})
                %>
              </p>
              <span
                class="badge <%= user.status === 'active' ? 'badge-active' : 'badge-inactive' %>"
              >
                <%= user.status %>
              </span>
            </div>
          </div>
        </div>

        <!-- Plan / Subscription card -->
        <div class="card">
          <h2>Subscription</h2>
          <% if (subscription) { %>
          <div class="plan-name"><%= subscription.plan_name %></div>
          <p class="plan-meta">
            Billing: <strong><%= subscription.billing_cycle %></strong>
            &nbsp;·&nbsp;
            <span
              class="badge badge-<%= subscription.status === 'active' ? 'active' : 'pending' %>"
            >
              <%= subscription.status %>
            </span>
          </p>
          <p class="plan-price">
            £<%= parseFloat(subscription.price_monthly).toFixed(2) %> / mo
          </p>
          <div class="plan-limits">
            <span>
              <strong><%= subscription.max_terminals %></strong>
              Terminal<%= subscription.max_terminals !== 1 ? 's' : '' %>
            </span>
            <span>
              <strong><%= subscription.max_users %></strong>
              User<%= subscription.max_users !== 1 ? 's' : '' %>
            </span>
          </div>
          <a class="btn-outline" href="/ContactSales">Upgrade plan</a>
          <% } else { %>
          <p class="no-data">No active subscription found.</p>
          <a class="btn-primary" href="/pricing">View plans</a>
          <% } %>
        </div>

        <!-- Billing address card -->
        <div class="card">
          <h2>Billing Address</h2>
          <% if (address) { %>
          <div class="address-block">
            <p><%= address.line_1 %></p>
            <% if (address.line_2) { %>
            <p><%= address.line_2 %></p>
            <% } %>
            <p><%= address.city %></p>
            <% if (address.county) { %>
            <p><%= address.county %></p>
            <% } %>
            <p><%= address.postcode %></p>
            <p><%= address.country %></p>
          </div>
          <% } else { %>
          <p class="no-data">No billing address on file.</p>
          <% } %>
          <a class="btn-outline" href="/ContactSales">Update address</a>
        </div>

        <!-- Recent orders card -->
        <div class="card">
          <h2>Recent Orders</h2>
          <% if (orders.length > 0) { %>
          <table class="data-table">
            <thead>
              <tr>
                <th>Order</th>
                <th>Items</th>
                <th>Total</th>
                <th>Status</th>
              </tr>
            </thead>
            <tbody>
              <% orders.forEach(order => { %>
              <tr>
                <td>
                  #<%= order.id %>
                  <div class="muted">
                    <%= new Date(order.created_at).toLocaleDateString('en-GB')
                    %>
                  </div>
                </td>
                <td><%= order.item_count %></td>
                <td>£<%= parseFloat(order.total).toFixed(2) %></td>
                <td>
                  <span
                    class="badge badge-<%= order.status === 'paid' || order.status === 'shipped' ? 'active' : 'pending' %>"
                  >
                    <%= order.status %>
                  </span>
                </td>
              </tr>
              <% }) %>
            </tbody>
          </table>
          <% } else { %>
          <p class="no-data">No orders yet.</p>
          <a class="btn-primary" href="/Shop">Visit the shop</a>
          <% } %>
        </div>

        <!-- Support tickets card -->
        <div class="card full-width">
          <h2>Open Support Tickets</h2>
          <% if (tickets.length > 0) { %> <% tickets.forEach(ticket => { %>
          <div class="ticket-row">
            <div>
              <div class="ticket-subject">
                #<%= ticket.id %> – <%= ticket.subject %>
              </div>
              <div class="ticket-date">
                Opened <%= new
                Date(ticket.created_at).toLocaleDateString('en-GB',{day:'numeric',month:'short',year:'numeric'})
                %>
              </div>
            </div>
            <div class="ticket-badges">
              <span
                class="badge badge-<%= ticket.priority === 'high' || ticket.priority === 'urgent' ? 'high' : 'open' %>"
              >
                <%= ticket.priority %>
              </span>
              <span class="badge badge-open"><%= ticket.status %></span>
            </div>
          </div>
          <% }) %> <% } else { %>
          <p class="no-data">No open tickets — all good!</p>
          <% } %>
          <a class="btn-outline" href="/ContactSales">Open a ticket</a>
        </div>
      </div>
      <!-- /grid -->
    </div>
    <!-- /dashboard -->

    <%- include('footer.ejs') %>
  </body>
</html>
